# ------------------------------------------------------------
# Evolution API self-hosted (copie para .env neste diretório)
# ------------------------------------------------------------

# URLs e portas
EVOLUTION_SERVER_URL=https://whatsapp.seudominio.com
EVOLUTION_PORT=8080

# Segurança
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=troque-para-uma-chave-forte

# Banco/Redis
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres:postgres@evolution-postgres:5432/evolution
REDIS_URI=redis://evolution-redis:6379

# Ambiente
NODE_ENV=production
LOG_LEVEL=warn

# Opcional
WEBSOCKET_ENABLED=true
DEL_INSTANCE=false

# Webhook default (pode configurar por instância)
# WEBHOOK_GLOBAL_ENABLED=true
# WEBHOOK_GLOBAL_URL=https://crm.seudominio.com/api/integrations/whatsapp/evolution/webhook
